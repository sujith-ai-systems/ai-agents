# --- Analyzer: Google Gemini ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Reviewer: Groq (free tier) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- Optional alternative reviewer providers ---
XAI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# --- Slack notifications (choose ONE mechanism) ---
# Option 1 (simplest): Incoming Webhook URL
#   Create at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Option 2: Bot token + channel (richer features)
#   Create app with chat:write scope at https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# --- A2A server (optional) ---
# A2A_HOST=0.0.0.0
# A2A_PORT=8000
# Public URL advertised in the Agent Card (e.g. an ngrok/Cloudflare tunnel)
# A2A_PUBLIC_URL=http://localhost:8000
